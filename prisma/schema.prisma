// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  
}
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone     String?
  gender    String?
  birthDate DateTime?
  createdAt DateTime @default(now())

  bookings Booking[]
  PasswordReset PasswordReset[]

}
model PasswordReset {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  codeHash  String    // bcrypt hash của mã 6 số
  expireAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum MovieStatus {
  COMING_SOON
  NOW_SHOWING
  ENDED
}


model Movie {
  id          Int       @id @default(autoincrement())
  tmdbId      Int?      @unique

  title       String
  description String? @db.Text
  duration    Int?      // optional vì TMDB không luôn có

  poster      String?
  backdrop    String?   // thêm cái này (ảnh nền)

  releaseDate DateTime?
  rating      Float?

  status      MovieStatus @default(COMING_SOON)

  createdAt   DateTime  @default(now())

  showtimes   Showtime[]
  cast        Cast[]
}
model Cast {
  id        Int    @id @default(autoincrement())
  name      String
  character String?
  profile   String?

  movieId   Int
  movie     Movie  @relation(fields: [movieId], references: [id])
}
model Cinema {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  createdAt DateTime @default(now())

  rooms     Room[]
}

model Room {
  id         Int    @id @default(autoincrement())
  cinemaId   Int
  name       String
  totalSeats Int

  cinema     Cinema @relation(fields: [cinemaId], references: [id])
  seats      Seat[]
  showtimes  Showtime[]
}

model Seat {
  id         Int    @id @default(autoincrement())
  roomId     Int
  seatNumber String

  room           Room           @relation(fields: [roomId], references: [id])
  showtimeSeats  ShowtimeSeat[]
}

model Showtime {
  id        Int      @id @default(autoincrement())
  movieId   Int
  roomId    Int
  startTime DateTime
  endTime   DateTime
  price     Decimal

  movie        Movie          @relation(fields: [movieId], references: [id])
  room         Room           @relation(fields: [roomId], references: [id])
  bookings     Booking[]
  showtimeSeats ShowtimeSeat[]
}
enum SeatStatus {
  AVAILABLE
  HOLD
  BOOKED
}
model ShowtimeSeat {
  id         Int    @id @default(autoincrement())
  showtimeId Int
  seatId     Int
  status     SeatStatus 
  holdUntil  DateTime?   
  showtime   Showtime @relation(fields: [showtimeId], references: [id])
  seat       Seat     @relation(fields: [seatId], references: [id])
  heldBy     Int?        


  bookingSeats BookingSeat[]

  @@unique([showtimeId, seatId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  showtimeId Int
  totalPrice Decimal
  status     BookingStatus
  createdAt  DateTime @default(now())

  user        User          @relation(fields: [userId], references: [id])
  showtime    Showtime      @relation(fields: [showtimeId], references: [id])
  bookingSeats BookingSeat[]
}

model BookingSeat {
  id             Int @id @default(autoincrement())
  bookingId      Int
  showtimeSeatId Int

  booking        Booking      @relation(fields: [bookingId], references: [id])
  showtimeSeat   ShowtimeSeat @relation(fields: [showtimeSeatId], references: [id])
}
